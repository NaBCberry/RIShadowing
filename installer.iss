; Inno Setup Script for AI_Interpreter
; Generated by build.py — do not edit manually

#define MyAppName "AI_Interpreter"
#define MyAppVersion "1.3.0"
#define MyAppPublisher "Rhodes Island Command System"
#define MyAppURL ""
#define MyAppExeName "AI_Interpreter.exe"

[Setup]
AppId={{8F1A2B3C-4D5E-6F78-9A0B-1C2D3E4F5G6H}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
AppPublisher={#MyAppPublisher}
DefaultDirName={autopf}\AI_Interpreter
DefaultGroupName=AI_Interpreter
UninstallDisplayIcon={app}\AI_Interpreter.exe
Compression=lzma2
SolidCompression=yes
OutputDir=dist_output
OutputBaseFilename=AI_Interpreter_{#MyAppVersion}_Setup
PrivilegesRequired=admin
DisableProgramGroupPage=yes
WizardStyle=modern

[Languages]
Name: "en"; MessagesFile: "compiler:Default.isl"

[Tasks]
Name: "desktopicon"; Description: "Create a desktop shortcut"; GroupDescription: "Shortcuts:"
Name: "startmenu"; Description: "Create a Start Menu group"; GroupDescription: "Shortcuts:"

[Files]
Source: "dist_work\AI_Interpreter\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{group}\AI_Interpreter"; Filename: "{app}\AI_Interpreter.exe"; WorkingDir: "{app}"
Name: "{group}\Uninstall AI_Interpreter"; Filename: "{uninstallexe}"
Name: "{autodesktop}\AI_Interpreter"; Filename: "{app}\AI_Interpreter.exe"; WorkingDir: "{app}"; Tasks: desktopicon

[Run]
Filename: "{app}\AI_Interpreter.exe"; Description: "Launch AI_Interpreter"; Flags: nowait postinstall skipifsilent

[UninstallRun]
Filename: "{cmd}"; Parameters: "/c rmdir /s /q ""{code:GetDataDir}"""; Flags: runhidden; Check: RemoveDataDirCheck

[Code]
var
  DataDirPage: TInputOptionWizardPage;

const
  optAppData = 0;
  optAppDir  = 1;

function GetDataDir(Param: string): string;
begin
  if DataDirPage.SelectedValueIndex = optAppData then
    Result := ExpandConstant('%APPDATA%\AI_Interpreter')
  else
    Result := ExpandConstant('{app}');
end;

function RemoveDataDirCheck: Boolean;
begin
  Result := MsgBox('Delete user data (config, records, models)?'#13#10
                   'Location: ' + GetDataDir(''),
                   mbConfirmation, MB_YESNO) = idYes;
end;

procedure InitializeWizard;
begin
  DataDirPage := CreateInputOptionPage(
    wpSelectDir,
    'User Data Directory',
    'Where should user data (records, config, models) be stored?',
    'This data is preserved during upgrades. Select [AppData] to keep your data safe when uninstalling.',
    True, False);

  DataDirPage.Add('AppData (Roaming)'#13#10'Recommended — survives reinstallation');
  DataDirPage.Add('Application folder'#13#10'Same directory as the program');

  DataDirPage.SelectedValueIndex := optAppData;
end;

procedure CurStepChanged(CurStep: TSetupStep);
var
  ConfigPath, DataDir: string;
  ConfigList: TStringList;
begin
  if CurStep = ssPostInstall then
  begin
    DataDir := GetDataDir('');
    ConfigPath := ExpandConstant('{app}\config.json');

    if not FileExists(ConfigPath) then
    begin
      ConfigList := TStringList.Create;
      try
        ConfigList.Add('{');
        ConfigList.Add('  "data_dir": "' + DataDir + '"');
        ConfigList.Add('}');
        ConfigList.SaveToFile(ConfigPath);
      finally
        ConfigList.Free;
      end;
    end;
  end;
end;
